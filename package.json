{
  "name": "whel-recorder",
  "productName": "WHEL Recorder",
  "version": "1.0.0",
  "description": "Premium gaming screen recorder and replay buffer software with process loopback audio",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.etherious.whelrecorder",
    "productName": "WHEL Recorder",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "application-loopback": "^1.2.7"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3"
  }
}
